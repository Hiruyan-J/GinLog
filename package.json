{
  "name": "app",
  "private": true,
  "devDependencies": {
    "esbuild": "^0.25.5",
    "rustywind": "^0.24.3"
  },
  "scripts": {
    "build": "esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets",
    "tailwind:sort": "rustywind --write --custom-regex 'class\\s*(?:=\\s*|:\\s*)\"(?![^\"]*(?:<%|#\\{))([^\"]+)\"' app/views/",
    "tailwind:check": "rustywind --check-formatted --custom-regex 'class\\s*(?:=\\s*|:\\s*)\"(?![^\"]*(?:<%|#\\{))([^\"]+)\"' app/views/"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.16",
    "daisyui": "^5.0.43",
    "tailwindcss": "^4.1.11"
  }
}
