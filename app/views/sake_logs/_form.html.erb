<%= form_with model: sake_log, url: sake_log.persisted? ? sake_log_path(sake_log.sake_log) : sake_logs_path do |f| %>
  <%= render 'shared/error_messages', object: f.object %>

  <section class="flex flex-col gap-6 items-center px-2">

    <%# 銘柄(オートコンプリート) %>
    <div class="flex flex-col w-full md:w-8/12"
         data-controller="brand-autocomplete"
         data-brand-autocomplete-search-url-value="<%= search_api_brands_path %>"
         data-brand-autocomplete-initial-brand-id-value="<%= sake_log.brand_id %>"
         data-brand-autocomplete-initial-brand-label-value="<%= sake_log.brand_label %>"
         data-brand-autocomplete-initial-brewery-name-value="<%= sake_log.brewery_display_name %>">
    
      <div class="flex items-baseline gap-2">
        <%= f.label :brand_id, class: "font-semibold required whitespace-nowrap" %>
        <span class="text-xs text-base-content/50">（蔵元のブランド名。例：獺祭、久保田、新政）</span>
      </div>

      <%# hidden フィールド(実際にサブミットされる値) %>
      <%= f.hidden_field :brand_id,
            data: { brand_autocomplete_target: "hiddenBrandId" } %>

      <%# オートコンプリートのテキスト入力欄（name属性なし、サブミット対象外） %>
      <input type="text"
            class="w-full input input-primary"
            placeholder="銘柄名を入力してください"
            autocomplete="off"
            data-brand-autocomplete-target="input"
            data-action="input->brand-autocomplete#onInput click->brand-autocomplete#onClick">

      <%# 候補リストのドロップダウン %>
      <div class="relative">
        <div class="hidden absolute top-0 right-0 left-0 z-10"
             data-brand-autocomplete-target="dropdown">
        </div>
      </div>

      <%# 蔵元の自動表示エリア（銘柄選択時に表示） %>
      <div class="mt-4">
        <label class="font-semibold required whitespace-nowrap">蔵元</label>
        <input type="text"
               class="w-full input input-bordered bg-base-200 text-base-content/70"
               disabled
               data-brand-autocomplete-target="breweryDisplay">
      </div>
    </div>

    <%# 商品名(オートコンプリート) %>
    <div class="flex flex-col w-full md:w-8/12"
         data-controller="product-name-autocomplete"
         data-product-name-autocomplete-search-url-value="<%= search_api_sakes_path %>"
         data-product-name-autocomplete-brand-id-value="<%= sake_log.brand_id %>"
         data-product-name-autocomplete-initial-sake-id-value="<%= sake_log.sake_id %>"
         data-product-name-autocomplete-initial-product-name-value="<%= sake_log.product_name %>">

      <div class="flex items-baseline gap-2">
        <%= f.label :product_name, class: "font-semibold required whitespace-nowrap" %>
        <span class="text-xs text-base-content/50">（銘柄内の個別の名前。例：磨き二割三分、千寿、No.6 R-type）</span>
      </div>

      <%# sake_id hidden フィールド(既存Sake選択時にセット) %>
      <%= f.hidden_field :sake_id,
            data: { product_name_autocomplete_target: "hiddenSakeId" } %>
      
      <%# 商品名入力欄(オートコンプリート + フリー入力兼用) %>
      <%= f.text_field :product_name, class: "w-full input input-primary",
            placeholder: "商品名を入力してください",
            autocomplete: "off",
            disabled: sake_log.brand_id.blank? && !sake_log.persisted?,
            data: {
              product_name_autocomplete_target: "input",
              action: "input->product-name-autocomplete#onInput click->product-name-autocomplete#onClick"
            } %>

      <%# 候補リストのドロップダウン %>
      <div class="relative">
        <div class="hidden absolute top-0 right-0 left-0 z-10"
             data-product-name-autocomplete-target="dropdown">
        </div>
      </div>
    </div>

    <%# 好み度 %>
    <div class="w-full md:w-8/12">
      <%= f.label :rating, class: "font-semibold required whitespace-nowrap" %>
      <div class="flex justify-between items-center w-full">
        <%# 画面左 好み度入力 %>
        <div class="flex gap-2 items-center rating rating-xl"
              data-controller="rating">
          <%# 好み度0 %>
          <%= f.radio_button :rating, SakeLog::RATING_MIN, class: "rating-hidden",
              id: "rating-0", aria: { label: "clear" },
               data: { action: "change->rating#select" } %>

          <%# 好み度1〜5　%>
          <% rating_range = (SakeLog::RATING_MIN + 1)..SakeLog::RATING_MAX %>
          <%# 初期表示の星色をrating値に応じて切り替え(nil→灰色、値あり→黄色) %>
          <% star_color = sake_log.rating.nil? ? "bg-stone-400" : "bg-yellow-300" %>
          <% rating_range.each do |i| %>
            <%= f.radio_button :rating, i, class: "mask mask-star-2 #{star_color}",
                id: "rating-#{i}", aria: { label: "#{i} star" },
                data: { rating_target: "star", action: "change->rating#select" } %>
          <% end %>
        </div>

        <%# 画面右 クリアボタン %>
        <label for="rating-0" class= "cursor-pointer">
          <span class="btn btn-outline btn-xs btn-primary">好み度 0</span>
        </label>
      </div>
    </div>

    <%# 香りの濃淡 %>
    <div class="w-full md:w-8/12">
      <%= f.label :aroma_strength, class: "font-semibold required whitespace-nowrap" %>
      <div class="w-full">
        <div class="px-5">
          <%= f.range_field :aroma_strength,
              min: SakeLog::AROMA_STRENGTH_MIN, max: SakeLog::AROMA_STRENGTH_MAX,
              step: 0.1, class: "w-full range range-primary" %>
        </div>
        <div class="flex justify-between mt-2 text-xs px-7.5">
          <span>|</span>
          <span>|</span>
          <span>|</span>
        </div>
        <div class="flex justify-between px-2.5 mt-2 text-xs">
          <span>穏やか</span>
          <span>中間</span>
          <span>華やか</span>
        </div>
      </div>
    </div>

    <%# 味の濃淡 %>
    <div class="w-full md:w-8/12">
      <%= f.label :taste_strength, class: "font-semibold required whitespace-nowrap" %>
      <div class="w-full">
        <div class="px-5">
          <%= f.range_field :taste_strength,
              min: SakeLog::TASTE_STRENGTH_MIN, max: SakeLog::TASTE_STRENGTH_MAX,
              step: 0.1, class: "w-full range range-primary" %>
        </div>
        <div class="flex justify-between mt-2 text-xs px-7.5">
          <span>|</span>
          <span>|</span>
          <span>|</span>
        </div>
        <div class="flex justify-between px-2.5 mt-2 text-xs">
          <span>スッキリ</span>
          <span>中間</span>
          <span>濃い</span>
        </div>
      </div>
    </div>

    <%# 感想 %>
    <div class="flex flex-col w-full md:w-8/12">
      <%= f.label :review, class: "font-semibold" %>
      <%= f.text_area :review, class: "w-full textarea textarea-primary" %>
    </div>

    <div class="flex gap-2 justify-center">
      <%= link_to "一覧に戻る", sake_logs_path, class: "btn btn-outline btn-primary md:btn-wide" %>
      <%= f.submit nil, class: "btn btn-primary md:btn-wide" %>
    </div>
  </section>
<% end %>
